DISCORD_TOKEN=
DISCORD_OWNER_ID=
ZEROCLAW_API_PORT=8787

# 0G network defaults
ZEROCLAW_0G_NETWORK_NAME=0G Galileo Testnet
ZEROCLAW_0G_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROCLAW_0G_CHAIN_ID=16602
ZEROCLAW_0G_EXPLORER_URL=https://chainscan-galileo.0g.ai

# macOS Keychain settings
# Do not put private keys in this file. Only reference the Keychain entry names here.
ZEROCLAW_KEYCHAIN_ACCOUNT=zeroclaw
ZEROCLAW_STEVE_ZC_KEYCHAIN_SERVICE=Steve_ZC_PRIVATE_KEY
ZEROCLAW_WOZ_ZC_KEYCHAIN_SERVICE=Woz_ZC_PRIVATE_KEY

# Steve_ZC must match this address when marketplace payments are enabled.
# Override this if your team is using a different funded Steve_ZC wallet.
ZEROCLAW_STEVE_ZC_EXPECTED_ADDRESS=0x5b340a8553d08B65Cebf303514B0415E3aD1E8f7

# Optional but recommended for a stable second agent identity.
ZEROCLAW_WOZ_ZC_EXPECTED_ADDRESS=

# Marketplace payment settings
ZEROCLAW_PAYMENT_MODE=dry-run
ZEROCLAW_MARKETPLACE_REWARD_WEI=1000000000000000

# Optional 0G inference proxy configuration.
# Leave these blank if you only want the deterministic marketplace demo in fallback mode.
ZEROCLAW_INFERENCE_URL=
ZEROCLAW_INFERENCE_MODEL=
ZEROCLAW_INFERENCE_API_KEY=

# Preferred per-agent 0G inference configuration.
# These override the shared ZEROCLAW_INFERENCE_* values above.
ZEROCLAW_STEVE_ZC_INFERENCE_URL=
ZEROCLAW_STEVE_ZC_INFERENCE_MODEL=
ZEROCLAW_STEVE_ZC_INFERENCE_API_KEY=
ZEROCLAW_WOZ_ZC_INFERENCE_URL=
ZEROCLAW_WOZ_ZC_INFERENCE_MODEL=
ZEROCLAW_WOZ_ZC_INFERENCE_API_KEY=

# Optional path to the 0G CLI if it is not available in PATH
ZEROCLAW_0G_COMPUTE_CLI=0g-compute-cli
