# Flare Coston2 RPC (optional — defaults to public endpoint)
FLARE_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# Agent wallets (never commit real private keys)
AGENT_A_PRIVATE_KEY=0x...
AGENT_B_PRIVATE_KEY=0x...

# Contract addresses (fill in after deployment)
TASK_REGISTRY_ADDRESS=0x...
VERIFIER_ADDRESS=0x...
TREASURY_ADDRESS=0x...
USDC_ADDRESS=0x...

# Agent B server
AGENT_B_PORT=3001
AGENT_B_URL=http://localhost:3001

# IPFS storage (leave blank to use local mock in Phase 1)
PINATA_JWT=
