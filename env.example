# AgentLevy Protocol — Environment Variables
# ⚠️  Never commit .env to GitHub — this file is in .gitignore

# ─── FLARE ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_deployer_private_key_here
COSTON2_RPC=https://coston2-api.flare.network/ext/C/rpc

# Set this after running: npx hardhat run scripts/deploy.js --network coston2
TREASURY_ADDRESS=

# ─── XRPL ────────────────────────────────────────────────────────────────────
XRPL_WALLET_SEED=your_xrpl_wallet_seed_here
AGENT_A_ADDRESS=your_agent_a_xrpl_address
AGENT_B_ADDRESS=your_agent_b_evm_address

# ─── AGENTLEVY FACILITATOR ───────────────────────────────────────────────────
PORT=3001
LEVY_BPS=50
FACILITATOR_URL=http://localhost:3001

# ─── ANTHROPIC (for mock provider) ──────────────────────────────────────────
# Admin API key — starts with sk-ant-admin...
# Only needed if using real Anthropic billing events
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# ─── DASHBOARD ───────────────────────────────────────────────────────────────
# Vite env vars must be prefixed with VITE_
VITE_TREASURY_ADDRESS=
